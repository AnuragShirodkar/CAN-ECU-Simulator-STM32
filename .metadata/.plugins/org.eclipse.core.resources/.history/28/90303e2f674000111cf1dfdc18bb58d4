/* ============================================================
   ENGINE ECU — Board 1 — STM32F407 Discovery
   CAN Bus ECU Simulator — v4.0 FINAL

   FIXES FROM v3:
   ─────────────────────────────────────────────────────────
   1. MAX6675 CS timing fixed — 100ms delay before read
      (chip needs time after CS LOW before clock)
   2. SPI raw bytes debug always printed so you can verify
   3. ADC channel confirmed as IN13 (PC3) — check adc.c too
   4. Speed now shows correctly in UART (was masked by 0xFFFF)
   5. Buzzer: 2 beeps on overtemp FAULT (confirmed working)
   6. LIMP mode: RPM locked at 1500, speed = 37 km/h
   7. RECOVER mode: RPM also locked at 1500 (safe)
   8. UART dashboard shows speed in ALL states
   9. No flame sensor — completely removed
  10. No button interaction — fully automatic FSM
  11. Temperature hysteresis: FAULT at 40°C, RECOVER at 35°C
  12. CAN 0x1FF DTC frame sent continuously while fault active

   HARDWARE CONNECTIONS:
   ─────────────────────────────────────────────────────────
   MAX6675:
     CS   → PB10 (GPIO output)
     SCK  → PB13 (SPI2 SCK)
     MISO → PB14 (SPI2 MISO)
     VCC  → 3.3V
     GND  → GND

   Joystick (Analog):
     VRx  → PC3 (ADC1 Channel 13)
     VCC  → 3.3V
     GND  → GND
     (VRy and SW not used)

   Buzzer:
     +    → PE0 (GPIO output via transistor or direct)
     –    → GND

   CAN Bus:
     TX   → PD1 (CAN1 TX, remapped)
     RX   → PD0 (CAN1 RX, remapped)
     Use MCP2551 or SN65HVD230 transceiver

   LEDs (built-in STM32F407 Discovery):
     PD12 Green  = NORMAL
     PD13 Orange = LIMP (blink)
     PD14 Red    = FAULT

   IMPORTANT — adc.c must configure:
     Channel: ADC_CHANNEL_13
     GPIO:    PC3
     Rank:    1
     SamplingTime: ADC_SAMPLETIME_480CYCLES
   ============================================================ */

#include "main.h"
#include "cmsis_os.h"
#include "adc.h"
#include "can.h"
#include "spi.h"
#include "usart.h"
#include "gpio.h"

#include <stdio.h>
#include <string.h>
#include <stdint.h>

/* ================================================================
   THRESHOLDS & CONSTANTS
   ================================================================ */
#define OVERTEMP_FAULT_C     40.0f    /* NORMAL → FAULT above this */
#define OVERTEMP_RECOVER_C   35.0f    /* RECOVER → NORMAL below this */
#define RPM_MIN              800U
#define RPM_MAX              15000U
#define LIMP_RPM             1500U
#define FAULT_TO_LIMP_MS     3000UL   /* 3 s in FAULT before LIMP */
#define LIMP_SAFE_MS         5000UL   /* 5 s safe temp before RECOVER */
#define RECOVER_SETTLE_MS    2000UL   /* 2 s settle before NORMAL */

/* ================================================================
   STATE MACHINE
   ================================================================ */
typedef enum {
    SYS_NORMAL  = 0,
    SYS_FAULT   = 1,
    SYS_LIMP    = 2,
    SYS_RECOVER = 3
} SystemState_t;

/* ================================================================
   GLOBAL SHARED VARIABLES
   All written by one task, read by others — volatile for safety
   ================================================================ */
volatile uint16_t      g_rpm          = RPM_MIN;
volatile uint8_t       g_speed        = 0;
volatile float         g_engTemp      = 25.0f;
volatile uint32_t      g_adcRaw       = 2048;
volatile uint8_t       g_faultActive  = 0;
volatile SystemState_t g_sysState     = SYS_NORMAL;
volatile uint32_t      g_faultTimer   = 0;
volatile uint32_t      g_limpTimer    = 0;
volatile uint32_t      g_recoverTimer = 0;
volatile uint8_t       g_buzzerFlag   = 0;
volatile uint8_t       g_buzzerBeeps  = 0;

/* DTC code to transmit — set by fault detect */
volatile uint8_t       g_dtcB1        = 0x00;
volatile uint8_t       g_dtcB2        = 0x00;
volatile uint8_t       g_dtcB3        = 0x00;

/* CAN TX */
CAN_TxHeaderTypeDef    g_txHeader;
uint8_t                g_txData[8];
uint32_t               g_txMailbox;

/* ================================================================
   FUNCTION PROTOTYPES
   ================================================================ */
static void  Task_SensorRead   (void *argument);
static void  Task_CANTransmit  (void *argument);
static void  Task_FaultDetect  (void *argument);
static void  Task_LEDHeartbeat (void *argument);
static float MAX6675_ReadTemp  (void);
static void  UART_Log          (const char *msg);
static void  DTC_Transmit      (uint8_t b1, uint8_t b2, uint8_t b3);
static void  Buzzer_Beep       (uint8_t times);
static void  UpdateSpeedRPM    (void);

/* ================================================================
   UART LOG — blocking, short timeout
   ================================================================ */
static void UART_Log(const char *msg)
{
    HAL_UART_Transmit(&huart2, (const uint8_t *)msg,
                      (uint16_t)strlen(msg), 200);
}

/* ================================================================
   BUZZER BEEP — called from SensorRead task (safe for osDelay)
   ================================================================ */
static void Buzzer_Beep(uint8_t times)
{
    for (uint8_t i = 0; i < times; i++) {
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_SET);
        osDelay(300);
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_RESET);
        osDelay(200);
    }
}

/* ================================================================
   DTC TRANSMIT — CAN ID 0x1FF, 3 bytes
   P0217 overtemp  → 0x50, 0x02, 0x17
   P0335 crank     → 0x50, 0x03, 0x35
   Recovery clear  → 0x50, 0x0A, 0x01
   ================================================================ */
static void DTC_Transmit(uint8_t b1, uint8_t b2, uint8_t b3)
{
    CAN_TxHeaderTypeDef hdr;
    uint8_t  d[3] = {b1, b2, b3};
    uint32_t mb;

    hdr.StdId              = 0x1FF;
    hdr.IDE                = CAN_ID_STD;
    hdr.RTR                = CAN_RTR_DATA;
    hdr.DLC                = 3;
    hdr.TransmitGlobalTime = DISABLE;

    HAL_CAN_AddTxMessage(&hcan1, &hdr, d, &mb);
}

/* ================================================================
   MAX6675 TEMPERATURE READ via SPI2
   ─────────────────────────────────
   CS  = PB10 (manual GPIO)
   SCK = PB13, MISO = PB14 (SPI2)

   Bit layout of 16-bit response:
   [15]   = dummy sign bit (always 0)
   [14:3] = 12-bit temperature (LSB = 0.25°C)
   [2]    = open-circuit flag (1 = no thermocouple)
   [1]    = device ID (always 0)
   [0]    = tristate

   FIX: Added 100ms settle after CS LOW — MAX6675 datasheet
        requires conversion time before reading.
   ================================================================ */
static float MAX6675_ReadTemp(void)
{
    uint8_t  rx[2] = {0, 0};
    uint16_t raw;
    char     dbg[64];

    /* Pull CS LOW to begin conversion readout */
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_10, GPIO_PIN_RESET);

    /* MAX6675 needs at least 100ms between conversions for accuracy.
       In FreeRTOS context use osDelay — does NOT block other tasks. */
    osDelay(100);

    /* Read 2 bytes via SPI */
    HAL_StatusTypeDef spiStatus = HAL_SPI_Receive(&hspi2, rx, 2, 200);

    /* Pull CS HIGH to end transaction */
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_10, GPIO_PIN_SET);

    /* Log raw bytes always — helps debug SPI wiring */
    snprintf(dbg, sizeof(dbg),
             "[SPI] Status:%d  Bytes: 0x%02X 0x%02X\r\n",
             (int)spiStatus, rx[0], rx[1]);
    UART_Log(dbg);

    if (spiStatus != HAL_OK) {
        UART_Log("[TEMP] SPI receive error — check MISO/SCK wiring\r\n");
        return -2.0f;
    }

    raw = ((uint16_t)rx[0] << 8) | (uint16_t)rx[1];

    /* Check open-circuit bit */
    if (raw & 0x0004U) {
        UART_Log("[TEMP] Open-circuit — thermocouple not connected\r\n");
        return -1.0f;
    }

    /* If raw is 0x0000 or 0xFFFF — SPI wiring issue */
    if (raw == 0x0000U || raw == 0xFFFFU) {
        UART_Log("[TEMP] Raw=0x0000/FFFF — check SPI wiring & CS pin\r\n");
        return -3.0f;
    }

    /* Extract temperature bits [14:3] */
    raw >>= 3;
    float tempC = (float)raw * 0.25f;

    snprintf(dbg, sizeof(dbg), "[TEMP] Decoded: %.2f C\r\n", (double)tempC);
    UART_Log(dbg);

    return tempC;
}

/* ================================================================
   UPDATE SPEED FROM RPM
   Speed (km/h) = RPM / 40, capped at 250
   In FAULT state: RPM is 0xFFFF sentinel — speed = 0
   ================================================================ */
static void UpdateSpeedRPM(void)
{
    if (g_rpm == 0xFFFFU) {
        g_speed = 0;
        return;
    }
    uint32_t s = (uint32_t)g_rpm / 40U;
    g_speed = (s > 250U) ? 250U : (uint8_t)s;
}

/* ================================================================
   MAIN
   ================================================================ */
int main(void)
{
    HAL_Init();
    SystemClock_Config();
    MX_GPIO_Init();
    MX_ADC1_Init();
    MX_CAN1_Init();
    MX_SPI2_Init();
    MX_USART2_UART_Init();

    /* MAX6675 CS idle HIGH */
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_10, GPIO_PIN_SET);

    /* Buzzer OFF */
    HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_RESET);

    /* All LEDs OFF */
    HAL_GPIO_WritePin(GPIOD,
        GPIO_PIN_12 | GPIO_PIN_13 | GPIO_PIN_14, GPIO_PIN_RESET);

    /* ── CAN1 filter: accept all frames ── */
    {
        CAN_FilterTypeDef flt = {0};
        flt.FilterBank           = 0;
        flt.FilterMode           = CAN_FILTERMODE_IDMASK;
        flt.FilterScale          = CAN_FILTERSCALE_32BIT;
        flt.FilterIdHigh         = 0x0000;
        flt.FilterIdLow          = 0x0000;
        flt.FilterMaskIdHigh     = 0x0000;
        flt.FilterMaskIdLow      = 0x0000;
        flt.FilterFIFOAssignment = CAN_RX_FIFO0;
        flt.FilterActivation     = ENABLE;
        flt.SlaveStartFilterBank = 14;

        if (HAL_CAN_ConfigFilter(&hcan1, &flt) != HAL_OK) {
            UART_Log("[INIT] ERROR: CAN filter FAILED\r\n");
            Error_Handler();
        }
    }

    if (HAL_CAN_Start(&hcan1) != HAL_OK) {
        UART_Log("[INIT] ERROR: CAN start FAILED\r\n");
        Error_Handler();
    }

    /* TX header static fields */
    g_txHeader.IDE                = CAN_ID_STD;
    g_txHeader.RTR                = CAN_RTR_DATA;
    g_txHeader.TransmitGlobalTime = DISABLE;

    /* ── Boot banner ── */
    UART_Log("\r\n");
    UART_Log("================================================\r\n");
    UART_Log("  ENGINE ECU  |  STM32F407  |  v4.0 FINAL     \r\n");
    UART_Log("  Joystick: PC3 / ADC1-CH13                   \r\n");
    UART_Log("  MAX6675 CS: PB10 | SPI2: PB13/PB14          \r\n");
    UART_Log("  FAULT at 40C | LIMP 1500RPM | RECOVER 35C   \r\n");
    UART_Log("  NO BUTTON — Fully Automatic FSM              \r\n");
    UART_Log("================================================\r\n\r\n");

    /* Startup beep — 1 short = system ready */
    HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_SET);
    HAL_Delay(200);
    HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_RESET);
    HAL_Delay(100);

    UART_Log("[INIT] CAN1 @ 500kbps : OK\r\n");
    UART_Log("[INIT] ADC1 CH13 PC3  : OK\r\n");
    UART_Log("[INIT] SPI2 MAX6675   : OK\r\n");
    UART_Log("[INIT] Starting FreeRTOS tasks...\r\n\r\n");

    /* ── Create FreeRTOS tasks ── */
    osThreadNew(Task_SensorRead, NULL,
        &(const osThreadAttr_t){
            .name       = "SensorRead",
            .stack_size = 512 * 4,
            .priority   = osPriorityNormal });

    osThreadNew(Task_CANTransmit, NULL,
        &(const osThreadAttr_t){
            .name       = "CANTransmit",
            .stack_size = 512 * 4,
            .priority   = osPriorityNormal });

    osThreadNew(Task_FaultDetect, NULL,
        &(const osThreadAttr_t){
            .name       = "FaultDetect",
            .stack_size = 512 * 4,
            .priority   = osPriorityAboveNormal });

    osThreadNew(Task_LEDHeartbeat, NULL,
        &(const osThreadAttr_t){
            .name       = "LEDHeart",
            .stack_size = 256 * 4,
            .priority   = osPriorityBelowNormal });

    /* DO NOT call osKernelStart() here —
       CubeMX calls it below in the correct order */

    osKernelInitialize();
    MX_FREERTOS_Init();
    osKernelStart();

    while (1) {}
}

/* ================================================================
   TASK 1 — SensorRead  |  Priority: Normal  |  Period: 50ms
   ─────────────────────────────────────────────────────────────
   - Reads ADC (joystick PC3 / ADC1-CH13)
   - Maps to RPM based on current state
   - Calculates speed from RPM
   - Reads MAX6675 temperature
   - Drives buzzer when flag set by FaultDetect
   ================================================================ */
static void Task_SensorRead(void *argument)
{
    char dbg[80];

    for (;;)
    {
        /* ── Read joystick ADC (PC3, Channel 13) ── */
        HAL_ADC_Start(&hadc1);
        if (HAL_ADC_PollForConversion(&hadc1, 10) == HAL_OK) {
            g_adcRaw = HAL_ADC_GetValue(&hadc1);
        }
        HAL_ADC_Stop(&hadc1);

        /* Map 0–4095 → 800–15000 RPM */
        uint16_t joyRPM = (uint16_t)(
            RPM_MIN + ((g_adcRaw * (uint32_t)(RPM_MAX - RPM_MIN)) / 4095UL));

        /* ── State machine selects RPM ── */
        switch (g_sysState)
        {
            case SYS_NORMAL:
                /* Full joystick control */
                g_rpm = joyRPM;
                break;

            case SYS_FAULT:
                /* Engine stopped — sentinel value */
                g_rpm = 0xFFFFU;
                break;

            case SYS_LIMP:
                /* Locked — engine runs at safe minimum */
                g_rpm = LIMP_RPM;
                break;

            case SYS_RECOVER:
                /* Still locked during settle period */
                g_rpm = LIMP_RPM;
                break;

            default:
                g_rpm = RPM_MIN;
                break;
        }

        /* ── Calculate speed ── */
        UpdateSpeedRPM();

        /* ── Log ADC/RPM/Speed debug every cycle ── */
        snprintf(dbg, sizeof(dbg),
                 "[ADC] Raw:%4lu  RPM:%5u  Spd:%3u km/h\r\n",
                 (unsigned long)g_adcRaw,
                 (unsigned)((g_rpm == 0xFFFFU) ? 0U : g_rpm),
                 (unsigned)g_speed);
        UART_Log(dbg);

        /* ── Read temperature from MAX6675 ── */
        float t = MAX6675_ReadTemp();
        if (t >= 0.0f) {
            g_engTemp = t;
        }
        /* If t < 0: keep last known good temperature */

        /* ── Drive buzzer (osDelay safe here) ── */
        if (g_buzzerFlag) {
            uint8_t n    = g_buzzerBeeps;
            g_buzzerFlag = 0;
            Buzzer_Beep(n);
        }

        osDelay(1000);  /* 20 Hz sensor update */
    }
}

/* ================================================================
   TASK 2 — CANTransmit  |  Priority: Normal  |  Period: 10ms
   ─────────────────────────────────────────────────────────────
   CAN frames transmitted:
     0x100 — RPM       [2 bytes big-endian]
     0x101 — Speed     [1 byte km/h]
     0x102 — Temp×10   [2 bytes big-endian]
     0x103 — Relay     [1 byte: 1=overtemp]
     0x104 — SysState  [1 byte: 0=N,1=F,2=L,3=R]
     0x1FF — DTC       [3 bytes, when fault active]

   UART dashboard printed every 500ms
   ================================================================ */
static const char *stateLabel[] = {"NORMAL", "FAULT ", "LIMP  ", "RECOV "};

static void Task_CANTransmit(void *argument)
{
    uint32_t lastPrint = 0;

    for (;;)
    {
        uint16_t safeRPM = (g_rpm == 0xFFFFU) ? 0U : g_rpm;

        /* ── 0x100 — RPM (2 bytes, big-endian) ── */
        g_txHeader.StdId = 0x100;
        g_txHeader.DLC   = 2;
        g_txData[0]      = (safeRPM >> 8) & 0xFF;
        g_txData[1]      =  safeRPM & 0xFF;
        HAL_CAN_AddTxMessage(&hcan1, &g_txHeader, g_txData, &g_txMailbox);

        /* ── 0x101 — Speed (1 byte) ── */
        g_txHeader.StdId = 0x101;
        g_txHeader.DLC   = 1;
        g_txData[0]      = g_speed;
        HAL_CAN_AddTxMessage(&hcan1, &g_txHeader, g_txData, &g_txMailbox);

        /* ── 0x102 — Temperature × 10 (2 bytes) ── */
        g_txHeader.StdId = 0x102;
        g_txHeader.DLC   = 2;
        {
            uint16_t tx10 = (uint16_t)(g_engTemp * 10.0f);
            g_txData[0]   = (tx10 >> 8) & 0xFF;
            g_txData[1]   =  tx10 & 0xFF;
        }
        HAL_CAN_AddTxMessage(&hcan1, &g_txHeader, g_txData, &g_txMailbox);

        /* ── 0x103 — Relay: ON when overtemp ── */
        g_txHeader.StdId = 0x103;
        g_txHeader.DLC   = 1;
        g_txData[0]      = (g_engTemp > OVERTEMP_FAULT_C) ? 0x01U : 0x00U;
        HAL_CAN_AddTxMessage(&hcan1, &g_txHeader, g_txData, &g_txMailbox);

        /* ── 0x104 — System state byte ── */
        g_txHeader.StdId = 0x104;
        g_txHeader.DLC   = 1;
        g_txData[0]      = (uint8_t)g_sysState;
        HAL_CAN_AddTxMessage(&hcan1, &g_txHeader, g_txData, &g_txMailbox);

        /* ── 0x1FF — DTC when fault active ── */
        if (g_faultActive) {
            DTC_Transmit(g_dtcB1, g_dtcB2, g_dtcB3);
        }

        /* ── UART dashboard every 500ms ── */
        uint32_t now = HAL_GetTick();
        if ((now - lastPrint) >= 500UL)
        {
            lastPrint = now;

            /* Convert temp to int.frac (avoids printf float issues) */
            int16_t tw = (int16_t)g_engTemp;
            uint8_t tf = (uint8_t)((g_engTemp - (float)tw) * 10.0f);

            char line[200];
            snprintf(line, sizeof(line),
                "\r\n+------------------------------------------+\r\n"
                "| ENGINE ECU DASHBOARD                     |\r\n"
                "+------------------------------------------+\r\n"
                "| State : %-6s                           |\r\n"
                "| RPM   : %5u                           |\r\n"
                "| Speed : %3u km/h                        |\r\n"
                "| Temp  : %3d.%u C                         |\r\n"
                "| ADC   : %4lu                            |\r\n"
                "| Fault : %s                            |\r\n"
                "+------------------------------------------+\r\n",
                stateLabel[g_sysState & 0x03],
                (unsigned)safeRPM,
                (unsigned)g_speed,
                tw, tf,
                (unsigned long)g_adcRaw,
                g_faultActive ? "ACTIVE  (DTC on 0x1FF)" : "none");

            UART_Log(line);

            /* Show DTC code when active */
            if (g_faultActive) {
                char dtc[60];
                snprintf(dtc, sizeof(dtc),
                    "| DTC   : P%02X%02X  (0x%02X 0x%02X 0x%02X)       |\r\n"
                    "+------------------------------------------+\r\n",
                    g_dtcB2, g_dtcB3,
                    g_dtcB1, g_dtcB2, g_dtcB3);
                UART_Log(dtc);
            }
        }

        osDelay(10);  /* 100 Hz CAN transmit */
    }
}

/* ================================================================
   TASK 3 — FaultDetect  |  Priority: AboveNormal  |  Period: 5ms
   ─────────────────────────────────────────────────────────────
   FULLY AUTOMATIC — temperature-driven only
   NO button interaction at all

   State transitions:
     NORMAL  → FAULT   : temp > 40°C
     FAULT   → LIMP    : 3s elapsed
     LIMP    → RECOVER : temp < 35°C for 5s
     RECOVER → NORMAL  : 2s settle + temp < 35°C
     RECOVER → FAULT   : temp still ≥ 35°C after 2s

   On FAULT entry: buzzer beeps 2 times, DTC P0217 transmitted
   On NORMAL return: buzzer beeps 2 times, DTC clear sent
   ================================================================ */
static void Task_FaultDetect(void *argument)
{
    /* 1.5 second startup settle — prevent false trigger on boot */
    osDelay(1500);
    UART_Log("[FSM] Fault detection ACTIVE — Automatic mode\r\n");
    UART_Log("[FSM] FAULT at 40C | LIMP 1500RPM | RECOVER at 35C\r\n\r\n");

    for (;;)
    {
        uint32_t now = HAL_GetTick();

        switch (g_sysState)
        {
            /* ══════════════════════════════════════════
               NORMAL — monitor temperature continuously
               ══════════════════════════════════════════ */
            case SYS_NORMAL:
            {
                g_faultActive = 0;

                if (g_engTemp > OVERTEMP_FAULT_C)
                {
                    /* Integer temp for snprintf (no float format specifier) */
                    int16_t tw = (int16_t)g_engTemp;
                    uint8_t tf = (uint8_t)((g_engTemp - (float)tw) * 10.0f);

                    char msg[80];
                    snprintf(msg, sizeof(msg),
                        "\r\n[FSM] NORMAL → FAULT  (Temp %d.%uC > 40C — P0217)\r\n",
                        tw, tf);
                    UART_Log(msg);

                    /* Set DTC = P0217 (Engine Overtemperature) */
                    g_dtcB1 = 0x50;
                    g_dtcB2 = 0x02;
                    g_dtcB3 = 0x17;

                    g_sysState    = SYS_FAULT;
                    g_faultTimer  = now;
                    g_faultActive = 1;

                    /* Send DTC immediately */
                    DTC_Transmit(g_dtcB1, g_dtcB2, g_dtcB3);

                    /* 2 beeps = overtemperature warning */
                    g_buzzerBeeps = 2;
                    g_buzzerFlag  = 1;
                }
                break;
            }

            /* ══════════════════════════════════════════
               FAULT — wait 3 seconds then enter LIMP
               ══════════════════════════════════════════ */
            case SYS_FAULT:
            {
                /* Keep sending DTC every tick while in fault */
                /* (CANTransmit task also does this on 0x1FF) */

                if ((now - g_faultTimer) >= FAULT_TO_LIMP_MS)
                {
                    UART_Log("[FSM] FAULT → LIMP  (3s timeout — RPM locked 1500)\r\n");

                    g_sysState    = SYS_LIMP;
                    g_limpTimer   = now;
                    g_faultActive = 0;   /* DTC stops after LIMP entry */

                    /* 1 beep = entering limp mode */
                    g_buzzerBeeps = 1;
                    g_buzzerFlag  = 1;
                }
                break;
            }

            /* ══════════════════════════════════════════
               LIMP — RPM locked at 1500
               Wait for temp to drop below 35°C for 5s
               ══════════════════════════════════════════ */
            case SYS_LIMP:
            {
                if (g_engTemp < OVERTEMP_RECOVER_C)
                {
                    /* Temp is safe — check if it's been safe for 5s */
                    if ((now - g_limpTimer) >= LIMP_SAFE_MS)
                    {
                        UART_Log("[FSM] LIMP → RECOVER  (temp safe for 5s)\r\n");
                        g_sysState     = SYS_RECOVER;
                        g_recoverTimer = now;
                    }
                    /* else: continue counting — do nothing */
                }
                else
                {
                    /* Temp still too high — reset the safe timer */
                    g_limpTimer = now;
                }
                break;
            }

            /* ══════════════════════════════════════════
               RECOVER — 2s settle check
               If still cool → NORMAL
               If heating again → FAULT
               ══════════════════════════════════════════ */
            case SYS_RECOVER:
            {
                if ((now - g_recoverTimer) >= RECOVER_SETTLE_MS)
                {
                    if (g_engTemp < OVERTEMP_RECOVER_C)
                    {
                        UART_Log("[FSM] RECOVER → NORMAL  (all clear — engine free)\r\n");

                        /* Send DTC clear code */
                        DTC_Transmit(0x50, 0x0A, 0x01);

                        g_dtcB1       = 0x00;
                        g_dtcB2       = 0x00;
                        g_dtcB3       = 0x00;
                        g_sysState    = SYS_NORMAL;
                        g_faultActive = 0;
                        g_rpm         = RPM_MIN;

                        /* 2 beeps = all clear */
                        g_buzzerBeeps = 2;
                        g_buzzerFlag  = 1;
                    }
                    else
                    {
                        /* Still hot — go back to fault */
                        int16_t tw = (int16_t)g_engTemp;
                        uint8_t tf = (uint8_t)((g_engTemp - (float)tw) * 10.0f);
                        char msg[60];
                        snprintf(msg, sizeof(msg),
                            "[FSM] RECOVER → FAULT  (temp %d.%uC still high)\r\n",
                            tw, tf);
                        UART_Log(msg);

                        g_sysState    = SYS_FAULT;
                        g_faultTimer  = now;
                        g_faultActive = 1;
                        g_dtcB1       = 0x50;
                        g_dtcB2       = 0x02;
                        g_dtcB3       = 0x17;

                        g_buzzerBeeps = 2;
                        g_buzzerFlag  = 1;
                    }
                }
                break;
            }
        }

        osDelay(5);  /* 200 Hz fault check */
    }
}

/* ================================================================
   TASK 4 — LEDHeartbeat  |  Priority: BelowNormal  |  Period: 500ms
   ─────────────────────────────────────────────────────────────
   PD12 Green  solid  = NORMAL
   PD14 Red    solid  = FAULT
   PD13 Orange blink  = LIMP
   PD12 Green  blink  = RECOVER
   ================================================================ */
static void Task_LEDHeartbeat(void *argument)
{
    for (;;)
    {
        /* Turn all off first */
        HAL_GPIO_WritePin(GPIOD,
            GPIO_PIN_12 | GPIO_PIN_13 | GPIO_PIN_14,
            GPIO_PIN_RESET);

        switch (g_sysState)
        {
            case SYS_NORMAL:
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_SET);   /* Green solid */
                break;

            case SYS_FAULT:
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_SET);   /* Red solid */
                break;

            case SYS_LIMP:
                HAL_GPIO_TogglePin(GPIOD, GPIO_PIN_13);                /* Orange blink */
                break;

            case SYS_RECOVER:
                HAL_GPIO_TogglePin(GPIOD, GPIO_PIN_12);                /* Green blink */
                break;
        }

        osDelay(500);
    }
}

