int main(void)
{
    /* USER CODE BEGIN 1 */
    /* USER CODE END 1 */

    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_CAN1_Init();
    MX_SPI1_Init();

    /* USER CODE BEGIN 2 */

    /* Buzzer and relay off */
    HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_RESET);
    HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1, GPIO_PIN_RESET);

    /* ── CAN1 filter: pass all frames ── */
    {
        CAN_FilterTypeDef flt;
        flt.FilterBank           = 0;
        flt.FilterMode           = CAN_FILTERMODE_IDMASK;
        flt.FilterScale          = CAN_FILTERSCALE_32BIT;
        flt.FilterIdHigh         = 0x0000;
        flt.FilterIdLow          = 0x0000;
        flt.FilterMaskIdHigh     = 0x0000;
        flt.FilterMaskIdLow      = 0x0000;
        flt.FilterFIFOAssignment = CAN_RX_FIFO0;
        flt.FilterActivation     = ENABLE;
        flt.SlaveStartFilterBank = 14;
        if (HAL_CAN_ConfigFilter(&hcan1, &flt) != HAL_OK)
            Error_Handler();
    }

    if (HAL_CAN_Start(&hcan1) != HAL_OK)
        Error_Handler();

    if (HAL_CAN_ActivateNotification(&hcan1, CAN_IT_RX_FIFO0_MSG_PENDING) != HAL_OK)
        Error_Handler();

    /* ── TFT init and static frame ── */
    ST7735_Init();
    ST7735_FillScreen(ST7735_BLACK);
    TFT_DrawStaticFrame();

    /* ── Create tasks ── */
    osThreadNew(Task_TFT_Update,     NULL,
        &(const osThreadAttr_t){ .name="TFTTask",
            .stack_size = 1024 * 4,
            .priority   = osPriorityNormal });

    osThreadNew(Task_ThresholdCheck, NULL,
        &(const osThreadAttr_t){ .name="ThreshTask",
            .stack_size = 512 * 4,
            .priority   = osPriorityAboveNormal });

    osThreadNew(Task_BuzzerHandler,  NULL,
        &(const osThreadAttr_t){ .name="BuzzTask",
            .stack_size = 256 * 4,
            .priority   = osPriorityNormal });

    osKernelStart();

    /* USER CODE END 2 */
    while (1) {}
}

/* ============================================================
   CAN RX INTERRUPT CALLBACK
   Keep minimal: store data only, no HAL_Delay, no printf.
   ============================================================ */
/* USER CODE BEGIN 4 */

void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan)
{
    CAN_RxHeaderTypeDef hdr;
    uint8_t             d[8];

    if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &hdr, d) != HAL_OK)
        return;

    rx_frameCount++;

    switch (hdr.StdId)
    {
        case 0x100: /* RPM */
            rx_rpm = ((uint16_t)d[0] << 8) | d[1];
            break;

        case 0x101: /* Speed */
            rx_speed = d[0];
            break;

        case 0x102: /* Temperature × 10 */
        {
            uint16_t t10 = ((uint16_t)d[0] << 8) | d[1];
            rx_temp = (float)t10 / 10.0f;
            break;
        }

        case 0x103: /* Relay command */
            rx_relay = d[0];
            HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1,
                d[0] ? GPIO_PIN_SET : GPIO_PIN_RESET);
            break;

        case 0x104: /* System state from Engine ECU */
            rx_sysState = (SystemState_t)(d[0] & 0x03);
            switch (rx_sysState) {
                case SYS_NORMAL:  strncpy((char *)stateStr, "NORMAL",  9); break;
                case SYS_FAULT:   strncpy((char *)stateStr, "FAULT",   9); break;
                case SYS_LIMP:    strncpy((char *)stateStr, "LIMP",    9); break;
                case SYS_RECOVER: strncpy((char *)stateStr, "RECOVER", 9); break;
            }
            break;

        case 0x1FE: /* Flame emergency */
            rx_sysState = SYS_FAULT;
            strncpy((char *)stateStr, "FLAME!", 9);
            strncpy((char *)dtcStr,   "P0217",  11);
            HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1, GPIO_PIN_RESET); /* relay OFF */
            buzzerBeeps = 5;
            buzzerFlag  = 1;
            break;

        case 0x1FF: /* DTC */
        {
            uint8_t  sys  = d[0];
            uint16_t code = ((uint16_t)d[1] << 8) | d[2];

            if      (sys == 0x50 && code == 0x0335)
                strncpy((char *)dtcStr, "P0335", 11);
            else if (sys == 0x50 && code == 0x0217)
                strncpy((char *)dtcStr, "P0217", 11);
            else if (sys == 0x50 && code == 0x0219)
                strncpy((char *)dtcStr, "P0219", 11);
            else if (sys == 0x50 && code == 0x0A01)
                strncpy((char *)dtcStr, "NONE",  11); /* recovery complete */
            else {
                char tmp[12];
                snprintf(tmp, sizeof(tmp), "%02X%04X", sys, code);
                strncpy((char *)dtcStr, tmp, 11);
            }
            buzzerBeeps = 3;
            buzzerFlag  = 1;
            break;
        }

        default:
            break;
    }

    displayDirty = 1;
}

/* ============================================================
   TASK IMPLEMENTATIONS
   ============================================================ */

/*
 * Task_TFT_Update — 100 ms period, Normal priority
 * Redraws live value cells on the TFT.
 */
static void Task_TFT_Update(void *argument)
{
    for (;;)
    {
        if (displayDirty)
        {
            displayDirty = 0;
            TFT_UpdateAllValues();
            HAL_GPIO_TogglePin(GPIOd, GPIO_PIN_12);
        }
        osDelay(100);
    }
}

/*
 * Task_ThresholdCheck — 50 ms period, AboveNormal priority
 * Local threshold validation as backup to Engine ECU state.
 * Updates LEDs and triggers buzzer on threshold crossings.
 */
static void Task_ThresholdCheck(void *argument)
{
    SystemState_t prevState = SYS_NORMAL;

    for (;;)
    {
        /* ── LED update based on received system state ── */
        switch (rx_sysState)
        {
            case SYS_NORMAL:
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_SET);
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_RESET);
                break;

            case SYS_FAULT:
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_SET);
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET);
                break;

            case SYS_LIMP:
                HAL_GPIO_TogglePin(GPIOD, GPIO_PIN_13);
                HAL_GPIO_WritePin(GPIOD,  GPIO_PIN_12, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(GPIOD,  GPIO_PIN_14, GPIO_PIN_RESET);
                break;

            case SYS_RECOVER:
                HAL_GPIO_TogglePin(GPIOD, GPIO_PIN_12);
                HAL_GPIO_WritePin(GPIOD,  GPIO_PIN_13, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(GPIOD,  GPIO_PIN_14, GPIO_PIN_RESET);
                break;
        }

        /* ── Local threshold checks (backup to Engine ECU) ── */

        /* RPM overspeed P0219 */
        if (rx_rpm != 0xFFFF && rx_rpm > 8000U &&
            rx_sysState == SYS_NORMAL)
        {
            strncpy((char *)dtcStr, "P0219", 11);
            displayDirty = 1;
            buzzerBeeps  = 1;
            buzzerFlag   = 1;
        }

        /* Temperature critical P0217 */
        if (rx_temp > 800.0f && rx_sysState == SYS_NORMAL)
        {
            strncpy((char *)dtcStr, "P0217", 11);
            HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1, GPIO_PIN_SET); /* relay ON */
            displayDirty = 1;
            buzzerBeeps  = 2;
            buzzerFlag   = 1;
        }

        /* DTC clear on recovery */
        if (rx_sysState == SYS_NORMAL &&
            strcmp((const char *)dtcStr, "NONE") != 0 &&
            strcmp((const char *)dtcStr, "P0335") != 0)
        {
            /* Only clear non-crankshaft DTCs automatically */
            strncpy((char *)dtcStr, "NONE", 11);
            HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1, GPIO_PIN_RESET);
            displayDirty = 1;
        }

        /* Buzzer on state change */
        if (rx_sysState != prevState)
        {
            prevState    = rx_sysState;
            displayDirty = 1;
        }

        osDelay(50);
    }
}

/*
 * Task_BuzzerHandler — 10 ms period, Normal priority
 * Consumes buzzerFlag and drives the buzzer safely outside ISR context.
 */
static void Task_BuzzerHandler(void *argument)
{
    for (;;)
    {
        if (buzzerFlag)
        {
            uint8_t n = buzzerBeeps;
            buzzerFlag = 0;
            Buzzer_Beep(n);
        }
        osDelay(10);
    }
}

