typedef enum {
    SYS_NORMAL  = 0,
    SYS_FAULT   = 1,
    SYS_LIMP    = 2,
    SYS_RECOVER = 3
} SystemState_t;

/* Data received from Engine ECU via CAN RX interrupt */
volatile uint16_t      rx_rpm       = 0;
volatile uint8_t       rx_speed     = 0;
volatile float         rx_temp      = 25.0f;
volatile uint8_t       rx_relay     = 0;
volatile SystemState_t rx_sysState  = SYS_NORMAL;
volatile uint32_t      rx_frameCount = 0;

/* DTC string for display — updated from CAN callback */
volatile char          dtcStr[12]    = "NONE";
volatile char          stateStr[10]  = "NORMAL";

/* Buzzer: set from ThresholdCheck or CAN callback, consumed by BuzzerHandler */
volatile uint8_t buzzerFlag  = 0;
volatile uint8_t buzzerBeeps = 0;

/* Display dirty flag — set true when values change significantly */
volatile uint8_t displayDirty = 1;

