/**
 ******************************************************************************
 * @file    main.c  —  BOARD 2: Dashboard ECU
 * @brief   CAN Bus ECU Simulator — Dashboard Node
 *
 * Hardware:  STM32F407G-DISC1
 * Display:   ST7735 1.8" TFT (SPI1 — SCK:PA5, MOSI:PA7, CS:PA4, DC:PA3, RST:PA2)
 * Actuators: Buzzer (PE0, active high), Relay (PE1, active high)
 * CAN:       CAN1 via TJA1050 — PD0(RX), PD1(TX) — 500 kbps
 *            Prescaler=6, BS1=11Tq, BS2=2Tq, APB1=42MHz
 * No UART:   All output via TFT display + onboard LEDs
 *
 * CAN Receive Table (from Engine ECU)
 * ------------------------------------
 *  0x100  Engine RPM      2 bytes  0xFFFF = sensor fault
 *  0x101  Vehicle Speed   1 byte   km/h
 *  0x102  Engine Temp     2 bytes  value / 10 = °C
 *  0x103  Relay Command   1 byte   0x01=ON 0x00=OFF
 *  0x104  System State    1 byte   0=NORMAL 1=FAULT 2=LIMP 3=RECOVER
 *  0x1FE  Flame Emergency 1 byte   0xFF = emergency
 *  0x1FF  DTC Code        3 bytes  [sys][hi][lo]
 *
 * TFT Layout (128 x 160 px, portrait)
 * -------------------------------------
 *  Row 0–17   Title bar (blue)
 *  Row 18–67  RPM panel (left) | Speed panel (right)
 *  Row 68–117 Temp panel (left) | State panel (right)
 *  Row 118–133 DTC strip
 *  Row 134–159 Status bar (frame counter + bus status)
 *
 * FreeRTOS Tasks
 * ---------------
 *  Task_TFT_Update       100 ms  Normal         refreshes all live values
 *  Task_ThresholdCheck    50 ms  AboveNormal    local threshold check + LEDs
 *  Task_BuzzerHandler     10 ms  Normal         drives buzzer from flag
 ******************************************************************************
 */

