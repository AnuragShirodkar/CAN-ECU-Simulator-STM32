/* ── Task_SensorRead ── */
static void Task_SensorRead(void *argument) {
    for (;;) {
        /* ADC Read */
        HAL_ADC_Start(&hadc1);
        if (HAL_ADC_PollForConversion(&hadc1, 10) == HAL_OK)
            g_adcRaw = HAL_ADC_GetValue(&hadc1);
        HAL_ADC_Stop(&hadc1);

        /* Map RPM */
        uint16_t joystickRPM = (uint16_t)(RPM_MIN + ((g_adcRaw * (uint32_t)(RPM_MAX - RPM_MIN)) / 4095UL));

        /* Select State RPM */
        switch (g_sysState) {
            case SYS_NORMAL:  g_rpm = joystickRPM; break;
            case SYS_LIMP:    g_rpm = 1500U;       break;
            case SYS_FAULT:   g_rpm = 0xFFFFU;     break;
            case SYS_RECOVER: g_rpm = joystickRPM; break;
            default:          g_rpm = RPM_MIN;     break;
        }

        /* Speed atomic update */
        if (g_rpm == 0xFFFFU) g_speed = 0U;
        else {
            uint32_t spd = (uint32_t)g_rpm / 40U;
            g_speed = (spd > 250U) ? 250U : (uint8_t)spd;
        }

        /* ── Integration Point: Temp logic from File 1 ── */
        float t = MAX6675_ReadTemp();
        if (t >= 0.0f) {
            g_engTemp = t;
        }

        if (g_buzzerFlag) {
            uint8_t n = g_buzzerBeeps;
            g_buzzerFlag = 0;
            Buzzer_Beep(n);
        }
        osDelay(50);
    }
}

