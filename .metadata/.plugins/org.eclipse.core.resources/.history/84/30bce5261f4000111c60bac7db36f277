int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_SPI1_Init();
  MX_CAN1_Init();
  MX_USART2_UART_Init();

  /* CAN Filter */
  CAN_FilterTypeDef filter;
  filter.FilterBank           = 0;
  filter.FilterMode           = CAN_FILTERMODE_IDMASK;
  filter.FilterScale          = CAN_FILTERSCALE_32BIT;
  filter.FilterIdHigh         = 0x0000;
  filter.FilterIdLow          = 0x0000;
  filter.FilterMaskIdHigh     = 0x0000;
  filter.FilterMaskIdLow      = 0x0000;
  filter.FilterFIFOAssignment = CAN_RX_FIFO0;
  filter.FilterActivation     = ENABLE;
  HAL_CAN_ConfigFilter(&hcan1, &filter);
  HAL_CAN_Start(&hcan1);
  HAL_CAN_ActivateNotification(&hcan1, CAN_IT_RX_FIFO0_MSG_PENDING);

  ST7735_Init();
  TFT_DrawDashboard();

  osKernelInitialize();

  tftTaskHandle = osThreadNew(Task_TFT_Update, NULL, &(osThreadAttr_t){.name = "TFTTask", .stack_size = 512, .priority = osPriorityNormal});
  thresholdTaskHandle = osThreadNew(Task_ThresholdCheck, NULL, &(osThreadAttr_t){.name = "ThreshTask", .stack_size = 512, .priority = osPriorityAboveNormal});
  buzzerTaskHandle = osThreadNew(Task_BuzzerHandler, NULL, &(osThreadAttr_t){.name = "BuzzTask", .stack_size = 256, .priority = osPriorityNormal});

  osKernelStart();
  while (1) {}
}

void Task_TFT_Update(void *argument)
{
  for(;;)
  {
    TFT_UpdateValues();
    osDelay(100);
  }
}

void Task_ThresholdCheck(void *argument)
{
  for(;;)
  {
    if(rxRPM == 0xFFFF)
    {
      strcpy(dtcString, "P0335-FAIL");
      faultCode = 1;
    }
    else if(rxTemp > 40.0f)
    {
      strcpy(dtcString, "P0217-HOT");
      faultCode = 1;
    }
    else
    {
      strcpy(dtcString, "SYSTEM-OK");
      faultCode = 0;
    }
    osDelay(50);
  }
}

void Task_BuzzerHandler(void *argument)
{
  for(;;)
  {
    if(buzzerFlag)
    {
      uint8_t count = buzzerBeeps;
      buzzerFlag = 0;
      for(uint8_t i = 0; i < count; i++)
      {
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_SET);
        osDelay(150);
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_RESET);
        osDelay(100);
      }
    }
    osDelay(10);
  }
}

void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan)
{
  CAN_RxHeaderTypeDef rxHeader;
  uint8_t rxData[8];
  if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &rxHeader, rxData) != HAL_OK) return;
  frameCount++;
  switch(rxHeader.StdId)
  {
    case 0x100: rxRPM = ((uint16_t)rxData[0] << 8) | rxData[1]; break;
    case 0x101: rxSpeed = rxData[0]; break;
    case 0x102: rxTemp = (((uint16_t)rxData[0] << 8) | rxData[1]) / 10.0f; break;
    case 0x103: rxRelay = rxData[0]; HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1, rxData[0] ? GPIO_PIN_SET : GPIO_PIN_RESET); break;
    case 0x1FF:
    {
      uint16_t code = ((uint16_t)rxData[1] << 8) | rxData[2];
      if(code == 0x0335) strcpy(dtcString, "P0335-DTC");
      else if(code == 0x0217) strcpy(dtcString, "P0217-DTC");
      faultCode = 1; buzzerFlag = 1; buzzerBeeps = 3;
      break;
    }
  }
}

