#include "st7735.h"
#include "fonts.h"
#include "spi.h"
#include <string.h>

// ---- LOW LEVEL ----
static void ST7735_Select() {
    HAL_GPIO_WritePin(ST7735_CS_PORT, ST7735_CS_PIN, GPIO_PIN_RESET);
}

static void ST7735_Unselect() {
    HAL_GPIO_WritePin(ST7735_CS_PORT, ST7735_CS_PIN, GPIO_PIN_SET);
}

static void ST7735_DC_Command() {
    HAL_GPIO_WritePin(ST7735_DC_PORT, ST7735_DC_PIN, GPIO_PIN_RESET);
}

static void ST7735_DC_Data() {
    HAL_GPIO_WritePin(ST7735_DC_PORT, ST7735_DC_PIN, GPIO_PIN_SET);
}

static void ST7735_Reset() {
    HAL_GPIO_WritePin(ST7735_RST_PORT, ST7735_RST_PIN, GPIO_PIN_RESET);
    HAL_Delay(5);
    HAL_GPIO_WritePin(ST7735_RST_PORT, ST7735_RST_PIN, GPIO_PIN_SET);
    HAL_Delay(5);
}

// ---- WRITE ----
static void ST7735_WriteCommand(uint8_t cmd) {
    ST7735_Select();
    ST7735_DC_Command();
    HAL_SPI_Transmit(&hspi1, &cmd, 1, HAL_MAX_DELAY);
    ST7735_Unselect();
}

static void ST7735_WriteData(uint8_t* data, size_t size) {
    ST7735_Select();
    ST7735_DC_Data();
    HAL_SPI_Transmit(&hspi1, data, size, HAL_MAX_DELAY);
    ST7735_Unselect();
}

// ---- INIT ----
void ST7735_Init(void) {
    ST7735_Reset();

    ST7735_WriteCommand(0x01); // SW reset
    HAL_Delay(150);

    ST7735_WriteCommand(0x11); // Sleep out
    HAL_Delay(150);

    ST7735_WriteCommand(0x3A);
    uint8_t data = 0x05;
    ST7735_WriteData(&data, 1); // 16-bit color

    ST7735_WriteCommand(0x29); // Display ON
    HAL_Delay(50);
}

// ---- ADDRESS WINDOW ----
static void ST7735_SetAddrWindow(uint16_t x0, uint16_t y0, uint16_t x1, uint16_t y1) {
    uint8_t data[4];

    ST7735_WriteCommand(0x2A);
    data[0] = x0 >> 8; data[1] = x0 & 0xFF;
    data[2] = x1 >> 8; data[3] = x1 & 0xFF;
    ST7735_WriteData(data, 4);

    ST7735_WriteCommand(0x2B);
    data[0] = y0 >> 8; data[1] = y0 & 0xFF;
    data[2] = y1 >> 8; data[3] = y1 & 0xFF;
    ST7735_WriteData(data, 4);

    ST7735_WriteCommand(0x2C);
}

// ---- DRAW ----
void ST7735_DrawPixel(uint16_t x, uint16_t y, uint16_t color) {
    uint8_t data[2] = {color >> 8, color & 0xFF};
    ST7735_SetAddrWindow(x, y, x, y);
    ST7735_WriteData(data, 2);
}

void ST7735_FillScreen(uint16_t color) {
    ST7735_SetAddrWindow(0, 0, 127, 159);

    uint8_t data[2] = {color >> 8, color & 0xFF};

    ST7735_Select();
    ST7735_DC_Data();

    for(uint32_t i = 0; i < 128 * 160; i++) {
        HAL_SPI_Transmit(&hspi1, data, 2, HAL_MAX_DELAY);
    }

    ST7735_Unselect();
}

void ST7735_DrawFilledRect(uint16_t x, uint16_t y, uint16_t w, uint16_t h, uint16_t color) {
    ST7735_SetAddrWindow(x, y, x+w-1, y+h-1);

    uint8_t data[2] = {color >> 8, color & 0xFF};

    ST7735_Select();
    ST7735_DC_Data();

    for(uint32_t i = 0; i < w * h; i++) {
        HAL_SPI_Transmit(&hspi1, data, 2, HAL_MAX_DELAY);
    }

    ST7735_Unselect();
}

// ---- TEXT ----
void ST7735_WriteString(uint16_t x, uint16_t y, char* str, uint16_t color) {
    while(*str) {
        for(uint8_t i = 0; i < 5; i++) {
            uint8_t line = font5x7[*str - 32][i];
            for(uint8_t j = 0; j < 8; j++) {
                if(line & 0x01)
                    ST7735_DrawPixel(x+i, y+j, color);
                line >>= 1;
            }
        }
        x += 6;
        str++;
    }
}
