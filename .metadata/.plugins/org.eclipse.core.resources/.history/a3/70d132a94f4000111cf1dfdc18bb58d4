/**
 ******************************************************************************
 * @file    main.c
 * @brief   STM32F407G — CAN TJA1050 | RPM/Speed | TFT ST7735 | Buzzer | LED
 *
 * FEATURES:
 *  - Potentiometer → ADC → RPM (0–15000) → Speed (km/h)
 *  - TFT 1.8" ST7735 display: RPM, Speed, Temp (32–36 °C), Status, DTC
 *  - CAN bus TX via TJA1050 (RPM + Speed frame broadcast @ 10 Hz)
 *  - Over-RPM (>14500): Buzzer beeps 2×, LED blinks, Status = "FAULT", DTC shown
 *  - Normal: Status = "NORMAL", no beep/blink
 *
 * TOOLCHAIN: STM32CubeIDE / HAL  (or raw CMSIS — HAL used here)
 * TARGET   : STM32F407G-DISC1
 ******************************************************************************
 */

