/* ============================================================
 *  MAIN
 * ============================================================ */
int main(void)
{
    HAL_Init();
    SystemClock_Config();

    MX_GPIO_Init();
    MX_ADC1_Init();
    MX_SPI1_Init();
    MX_CAN1_Init();

    /* Start CAN */
    HAL_CAN_Start(&hcan1);

    /* Init TFT and draw static UI */
    TFT_Init();
    TFT_FillRect(0, 0, TFT_WIDTH, TFT_HEIGHT, BLACK);
    TFT_DrawUI_Static();

    uint32_t last_can_tick = 0;

    while (1)
    {
        /* ---- 1. Read ADC → RPM → Speed ---- */
        g_rpm   = ADC_ReadRPM();
        g_speed = (uint32_t)(g_rpm * SPEED_FACTOR);
        g_temp  = SimulateTemp();

        /* ---- 2. Fault detection ---- */
        if (g_rpm > RPM_FAULT_LEVEL)
        {
            if (!g_fault)
            {
                g_fault = 1;
                Buzzer_Beep2x();
                /* Drop RPM — in real ECU you'd cut fuel/throttle.
                   Here we simulate the drop for display purposes.      */
                g_rpm   = 9000 + (rand() % 1000);  /* 8000–10000 */
                g_speed = (uint32_t)(g_rpm * SPEED_FACTOR);
            }
            Handle_FaultState();
        }
        else
        {
            g_fault = 0;
            Handle_NormalState();
        }

        /* ---- 3. Update TFT values ---- */
        TFT_UpdateValues();

        /* ---- 4. CAN TX @ ~10 Hz ---- */
        uint32_t now = HAL_GetTick();
        if ((now - last_can_tick) >= 100)
        {
            last_can_tick = now;
            CAN_SendFrame(g_rpm, g_speed);
        }

        HAL_Delay(50); /* Main loop ~20 Hz */
    }
}

/* ============================================================
 *  ADC — Read pot, scale to 0–15000 RPM
 * ============================================================ */
static uint32_t ADC_ReadRPM(void)
{
    HAL_ADC_Start(&hadc1);
    HAL_ADC_PollForConversion(&hadc1, 10);
    uint32_t raw = HAL_ADC_GetValue(&hadc1);
    HAL_ADC_Stop(&hadc1);
    /* 12-bit ADC: 0–4095 → 0–RPM_MAX */
    return (raw * RPM_MAX) / 4095;
}

/* ============================================================
 *  CAN TX — Send RPM + Speed in 8-byte frame
 *  Byte 0–1 : RPM  (big-endian)
 *  Byte 2–3 : Speed (big-endian)
 *  Byte 4   : Fault flag (0x00 / 0x01)
 *  Byte 5   : Temperature
 *  Byte 6–7 : 0xAA 0x55 (frame marker)
 * ============================================================ */
static void CAN_SendFrame(uint32_t rpm, uint32_t speed)
{
    CAN_TxHeaderTypeDef hdr = {
        .StdId              = CAN_TX_ID,
        .ExtId              = 0,
        .IDE                = CAN_ID_STD,
        .RTR                = CAN_RTR_DATA,
        .DLC                = 8,
        .TransmitGlobalTime = DISABLE
    };
    uint8_t data[8];
    data[0] = (rpm   >> 8) & 0xFF;
    data[1] = (rpm)        & 0xFF;
    data[2] = (speed >> 8) & 0xFF;
    data[3] = (speed)      & 0xFF;
    data[4] = g_fault;
    data[5] = (uint8_t)g_temp;
    data[6] = 0xAA;
    data[7] = 0x55;

    uint32_t mailbox;
    HAL_CAN_AddTxMessage(&hcan1, &hdr, data, &mailbox);
}

/* ============================================================
 *  BUZZER — 2 beeps (blocking, short duration)
 * ============================================================ */
static void Buzzer_Beep2x(void)
{
    for (uint8_t i = 0; i < 2; i++)
    {
        HAL_GPIO_WritePin(BUZZER_PORT, BUZZER_PIN, GPIO_PIN_SET);
        HAL_Delay(BEEP_ON_MS);
        HAL_GPIO_WritePin(BUZZER_PORT, BUZZER_PIN, GPIO_PIN_RESET);
        HAL_Delay(BEEP_OFF_MS);
    }
}

/* ============================================================
 *  TEMPERATURE — simulate 32–36 °C with slow drift
 * ============================================================ */
static uint32_t SimulateTemp(void)
{
    static uint32_t t   = 34;
    static uint32_t cnt = 0;
    if (++cnt >= 20)   /* change every ~1 s at 50 ms loop */
    {
        cnt = 0;
        int32_t delta = (rand() % 3) - 1;  /* -1, 0, +1 */
        int32_t nt    = (int32_t)t + delta;
        if (nt < (int32_t)TEMP_MIN) nt = TEMP_MIN;
        if (nt > (int32_t)TEMP_MAX) nt = TEMP_MAX;
        t = (uint32_t)nt;
    }
    return t;
}

/* ============================================================
 *  FAULT STATE — LED blink (non-blocking)
 * ============================================================ */
static void Handle_FaultState(void)
{
    uint32_t now = HAL_GetTick();
    if ((now - g_tick_led) >= BLINK_PERIOD_MS)
    {
        g_tick_led  = now;
        g_led_state = !g_led_state;
        HAL_GPIO_WritePin(LED_PORT, LED_PIN,
                          g_led_state ? GPIO_PIN_SET : GPIO_PIN_RESET);
    }
}

/* ============================================================
 *  NORMAL STATE — LED off
 * ============================================================ */
static void Handle_NormalState(void)
{
    HAL_GPIO_WritePin(LED_PORT, LED_PIN, GPIO_PIN_RESET);
    g_led_state = 0;
}

/* ============================================================
 *  TFT LOW-LEVEL
 * ============================================================ */
static void TFT_WriteCmd(uint8_t cmd)
{
    TFT_DC_LOW();
    TFT_CS_LOW();
    HAL_SPI_Transmit(&hspi1, &cmd, 1, 10);
    TFT_CS_HIGH();
}

static void TFT_WriteData(uint8_t data)
{
    TFT_DC_HIGH();
    TFT_CS_LOW();
    HAL_SPI_Transmit(&hspi1, &data, 1, 10);
    TFT_CS_HIGH();
}

static void TFT_WriteColor(uint16_t color)
{
    uint8_t buf[2] = { color >> 8, color & 0xFF };
    TFT_DC_HIGH();
    TFT_CS_LOW();
    HAL_SPI_Transmit(&hspi1, buf, 2, 10);
    TFT_CS_HIGH();
}

/* ============================================================
 *  TFT INIT — ST7735 1.8" 128×160
 * ============================================================ */
static void TFT_Init(void)
{
    /* Hardware reset */
    TFT_RST_LOW();
    HAL_Delay(100);
    TFT_RST_HIGH();
    HAL_Delay(100);

    TFT_WriteCmd(ST7735_SWRESET); HAL_Delay(150);
    TFT_WriteCmd(ST7735_SLPOUT);  HAL_Delay(255);

    /* Frame rate */
    TFT_WriteCmd(ST7735_FRMCTR1);
    TFT_WriteData(0x01); TFT_WriteData(0x2C); TFT_WriteData(0x2D);

    /* Power */
    TFT_WriteCmd(ST7735_PWCTR1);
    TFT_WriteData(0xA2); TFT_WriteData(0x02); TFT_WriteData(0x84);
    TFT_WriteCmd(ST7735_PWCTR2);
    TFT_WriteData(0xC5);
    TFT_WriteCmd(ST7735_VMCTR1);
    TFT_WriteData(0x0A); TFT_WriteData(0xFF);

    /* Pixel format: 16-bit */
    TFT_WriteCmd(ST7735_COLMOD); TFT_WriteData(0x05);

    /* Memory direction: BGR, row-col swap for landscape/portrait */
    TFT_WriteCmd(ST7735_MADCTL); TFT_WriteData(0xC8);

    TFT_WriteCmd(ST7735_INVOFF);
    TFT_WriteCmd(ST7735_NORON); HAL_Delay(10);
    TFT_WriteCmd(ST7735_DISPON); HAL_Delay(100);
}

static void TFT_SetWindow(uint8_t x0, uint8_t y0, uint8_t x1, uint8_t y1)
{
    TFT_WriteCmd(ST7735_CASET);
    TFT_WriteData(0x00); TFT_WriteData(x0);
    TFT_WriteData(0x00); TFT_WriteData(x1);
    TFT_WriteCmd(ST7735_RASET);
    TFT_WriteData(0x00); TFT_WriteData(y0);
    TFT_WriteData(0x00); TFT_WriteData(y1);
    TFT_WriteCmd(ST7735_RAMWR);
}

static void TFT_FillRect(uint8_t x, uint8_t y, uint8_t w, uint8_t h, uint16_t color)
{
    TFT_SetWindow(x, y, x + w - 1, y + h - 1);
    uint8_t hi = color >> 8, lo = color & 0xFF;
    TFT_DC_HIGH();
    TFT_CS_LOW();
    for (uint32_t i = 0; i < (uint32_t)w * h; i++)
    {
        HAL_SPI_Transmit(&hspi1, &hi, 1, 5);
        HAL_SPI_Transmit(&hspi1, &lo, 1, 5);
    }
    TFT_CS_HIGH();
}

/* ============================================================
 *  DRAW CHAR — 5×7 font, scalable
 * ============================================================ */
static void TFT_DrawChar(uint8_t x, uint8_t y, char c,
                          uint16_t fg, uint16_t bg, uint8_t scale)
{
    if (c < 32 || c > 122) c = '?';
    const uint8_t *glyph = Font5x7[c - 32];
    for (uint8_t col = 0; col < 5; col++)
    {
        uint8_t colData = glyph[col];
        for (uint8_t row = 0; row < 7; row++)
        {
            uint16_t color = (colData & (1 << row)) ? fg : bg;
            TFT_FillRect(x + col * scale, y + row * scale, scale, scale, color);
        }
    }
    /* 1-pixel gap column */
    TFT_FillRect(x + 5 * scale, y, scale, 7 * scale, bg);
}

static void TFT_DrawString(uint8_t x, uint8_t y, const char *str,
                            uint16_t fg, uint16_t bg, uint8_t scale)
{
    while (*str)
    {
        TFT_DrawChar(x, y, *str++, fg, bg, scale);
        x += 6 * scale;
        if (x + 6 * scale > TFT_WIDTH) break;
    }
}

/* ============================================================
 *  UI LAYOUT (128 × 160 px)
 *
 *   ┌──────────────────────────┐  y=0
 *   │  ██ DASHBOARD ██         │  header bar   (h=18)
 *   ├──────────────────────────┤  y=18
 *   │  RPM                     │  label        (h=12)
 *   │  [    00000    ]         │  value box    (h=26)
 *   ├──────────────────────────┤  y=56
 *   │  SPEED                   │  label        (h=12)
 *   │  [    000 km/h ]         │  value box    (h=26)
 *   ├──────────────────────────┤  y=94
 *   │  TEMP   34 °C            │  single row   (h=20)
 *   ├──────────────────────────┤  y=114
 *   │  STATUS: NORMAL          │  status bar   (h=20)
 *   ├──────────────────────────┤  y=134
 *   │  DTC: ---                │  DTC row      (h=26)
 *   └──────────────────────────┘  y=160
 * ============================================================ */

/* --- Y positions --- */
#define Y_HEADER      0
#define Y_RPM_LBL    18
#define Y_RPM_VAL    30
#define Y_SPD_LBL    58
#define Y_SPD_VAL    70
#define Y_TEMP_ROW   98
#define Y_STATUS_ROW 118
#define Y_DTC_ROW    138

static void TFT_DrawUI_Static(void)
{
    /* Header bar */
    TFT_FillRect(0, Y_HEADER, TFT_WIDTH, 18, BLUE);
    TFT_DrawString(10, Y_HEADER + 5, "-- DASHBOARD --", WHITE, BLUE, 1);

    /* RPM section background */
    TFT_FillRect(0, Y_RPM_LBL, TFT_WIDTH, 10, DKGRAY);
    TFT_DrawString(2, Y_RPM_LBL + 1, "RPM", CYAN, DKGRAY, 1);

    TFT_FillRect(0, Y_RPM_VAL, TFT_WIDTH, 26, DGRAY);

    /* Speed section */
    TFT_FillRect(0, Y_SPD_LBL, TFT_WIDTH, 10, DKGRAY);
    TFT_DrawString(2, Y_SPD_LBL + 1, "SPEED (km/h)", YELLOW, DKGRAY, 1);

    TFT_FillRect(0, Y_SPD_VAL, TFT_WIDTH, 26, DGRAY);

    /* Temp row */
    TFT_FillRect(0, Y_TEMP_ROW, TFT_WIDTH, 18, DKGRAY);
    TFT_DrawString(2, Y_TEMP_ROW + 5, "TEMP:", WHITE, DKGRAY, 1);

    /* Status / DTC rows — filled in UpdateValues */
}

/* ============================================================
 *  TFT UPDATE — called every loop iteration
 * ============================================================ */
static void TFT_UpdateValues(void)
{
    char buf[20];

    /* ---- RPM value ---- */
    TFT_FillRect(0, Y_RPM_VAL, TFT_WIDTH, 26, DGRAY);
    snprintf(buf, sizeof(buf), "%05lu", (unsigned long)g_rpm);
    /* Center: 5 chars × 6px × scale=3 = 90px wide → start at (128-90)/2=19 */
    TFT_DrawString(14, Y_RPM_VAL + 4, buf,
                   g_fault ? RED : GREEN, DGRAY, 3);

    /* ---- Speed value ---- */
    TFT_FillRect(0, Y_SPD_VAL, TFT_WIDTH, 26, DGRAY);
    snprintf(buf, sizeof(buf), "%03lu", (unsigned long)g_speed);
    TFT_DrawString(22, Y_SPD_VAL + 4, buf, YELLOW, DGRAY, 3);

    /* ---- Temperature ---- */
    TFT_FillRect(40, Y_TEMP_ROW, 88, 18, DKGRAY);
    snprintf(buf, sizeof(buf), "%lu C", (unsigned long)g_temp);
    TFT_DrawString(42, Y_TEMP_ROW + 5, buf, ORANGE, DKGRAY, 1);

    /* ---- Status bar ---- */
    if (g_fault != g_prev_fault)
    {
        g_prev_fault = g_fault;

        if (g_fault)
        {
            /* FAULT — red bar */
            TFT_FillRect(0, Y_STATUS_ROW, TFT_WIDTH, 18, RED);
            TFT_DrawString(2, Y_STATUS_ROW + 5, "STATUS: FAULT   ", WHITE, RED, 1);

            /* DTC row */
            TFT_FillRect(0, Y_DTC_ROW, TFT_WIDTH, 22, BLACK);
            TFT_DrawString(2, Y_DTC_ROW + 3, "DTC:P0219-OVRPM", YELLOW, BLACK, 1);
        }
        else
        {
            /* NORMAL — green bar */
            TFT_FillRect(0, Y_STATUS_ROW, TFT_WIDTH, 18, GREEN);
            TFT_DrawString(2, Y_STATUS_ROW + 5, "STATUS: NORMAL  ", BLACK, GREEN, 1);

            /* Clear DTC row */
            TFT_FillRect(0, Y_DTC_ROW, TFT_WIDTH, 22, BLACK);
            TFT_DrawString(2, Y_DTC_ROW + 3, "DTC: ---        ", GRAY, BLACK, 1);
        }
    }
}

