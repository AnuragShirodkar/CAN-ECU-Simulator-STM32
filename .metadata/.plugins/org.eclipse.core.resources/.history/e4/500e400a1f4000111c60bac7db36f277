void TFT_DrawDashboard(void)
{
  ST7735_FillScreen(ST7735_BLACK);
  ST7735_FillRectangle(0, 0, 160, 18, ST7735_BLUE);
  ST7735_WriteString(10, 4, "ECU DASHBOARD V2.1", Font_7x10, ST7735_WHITE, ST7735_BLUE);

  ST7735_DrawRectangle(2, 22, 76, 50, ST7735_CYAN);
  ST7735_WriteString(5, 25, "RPM", Font_7x10, ST7735_CYAN, ST7735_BLACK);

  ST7735_DrawRectangle(82, 22, 76, 50, ST7735_GREEN);
  ST7735_WriteString(85, 25, "SPEED", Font_7x10, ST7735_GREEN, ST7735_BLACK);

  ST7735_DrawRectangle(2, 76, 76, 50, ST7735_RED);
  ST7735_WriteString(5, 79, "TEMP C", Font_7x10, ST7735_RED, ST7735_BLACK);

  ST7735_DrawRectangle(82, 76, 76, 50, ST7735_YELLOW);
  ST7735_WriteString(85, 79, "STATUS", Font_7x10, ST7735_YELLOW, ST7735_BLACK);

  ST7735_FillRectangle(0, 130, 160, 28, ST7735_DARKGREY);
  ST7735_WriteString(5, 134, "CAN: 500kbps", Font_7x10, ST7735_WHITE, ST7735_DARKGREY);
}

void TFT_UpdateValues(void)
{
  char buf[16];

  /* RPM Display */
  if(rxRPM == 0xFFFF) sprintf(buf, "FAULT");
  else sprintf(buf, "%-5d", rxRPM);
  ST7735_FillRectangle(4, 38, 72, 18, ST7735_BLACK);
  ST7735_WriteString(4, 38, buf, Font_11x18, ST7735_CYAN, ST7735_BLACK);

  /* Speed Display */
  sprintf(buf, "%3d km/h", rxSpeed);
  ST7735_FillRectangle(84, 38, 72, 18, ST7735_BLACK);
  ST7735_WriteString(84, 38, buf, Font_7x10, ST7735_GREEN, ST7735_BLACK);

  /* Temp Display */
  sprintf(buf, "%5.1f", rxTemp);
  ST7735_FillRectangle(4, 92, 72, 18, ST7735_BLACK);
  ST7735_WriteString(4, 92, buf, Font_11x18, ST7735_RED, ST7735_BLACK);

  /* Status / DTC Display */
  ST7735_FillRectangle(84, 92, 72, 18, ST7735_BLACK);
  uint16_t statusColor = (faultCode > 0) ? ST7735_RED : ST7735_GREEN;
  ST7735_WriteString(84, 92, dtcString, Font_7x10, statusColor, ST7735_BLACK);

  /* Frame Counter */
  sprintf(buf, "FRM:%d", frameCount);
  ST7735_FillRectangle(90, 134, 68, 12, ST7735_DARKGREY);
  ST7735_WriteString(90, 134, buf, Font_7x10, ST7735_WHITE, ST7735_DARKGREY);
}
