/* ── Task 1: Update TFT ── */
void Task_TFT_Update(void *argument)
{
  for(;;)
  {
    TFT_UpdateValues();
    osDelay(100);
  }
}

/* ── Task 2: Threshold & Dashboard Logic ── */
void Task_ThresholdCheck(void *argument)
{
  for(;;)
  {
    /* Local logic to match Dashboard state with received CAN data */
    if(rxRPM == 0xFFFF)
    {
      strcpy(dtcString, "P0335-FAIL");
      faultCode = 1;
    }
    else if(rxTemp > 40.0f) /* Matching 40.0C room-demo threshold from Engine ECU */
    {
      strcpy(dtcString, "P0217-HOT");
      faultCode = 1;
    }
    else
    {
      strcpy(dtcString, "SYSTEM-OK");
      faultCode = 0;
    }
    osDelay(50);
  }
}

/* ── Task 3: Buzzer Handler ── */
void Task_BuzzerHandler(void *argument)
{
  for(;;)
  {
    if(buzzerFlag)
    {
      uint8_t count = buzzerBeeps;
      buzzerFlag = 0;
      for(uint8_t i = 0; i < count; i++)
      {
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_SET);
        osDelay(150);
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_RESET);
        osDelay(100);
      }
    }
    osDelay(10);
  }
}

/* ── CAN RX Callback (Flame Logic Removed) ── */
void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan)
{
  CAN_RxHeaderTypeDef rxHeader;
  uint8_t rxData[8];

  if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &rxHeader, rxData) != HAL_OK) return;

  frameCount++;

  switch(rxHeader.StdId)
  {
    case 0x100: /* RPM */
      rxRPM = ((uint16_t)rxData[0] << 8) | rxData[1];
      break;

    case 0x101: /* Speed */
      rxSpeed = rxData[0];
      break;

    case 0x102: /* Temp */
      rxTemp = (((uint16_t)rxData[0] << 8) | rxData[1]) / 10.0f;
      break;

    case 0x103: /* Relay (Overtemp indicator) */
      rxRelay = rxData[0];
      HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1, rxData[0] ? GPIO_PIN_SET : GPIO_PIN_RESET);
      break;

    case 0x1FF: /* DTC Received from Engine ECU */
    {
      uint16_t code = ((uint16_t)rxData[1] << 8) | rxData[2];
      if(code == 0x0335) strcpy(dtcString, "P0335-DTC");
      else if(code == 0x0217) strcpy(dtcString, "P0217-DTC");

      faultCode = 1;
      buzzerFlag = 1;
      buzzerBeeps = 3;
      break;
    }
    /* Case 0x1FE (Flame Sensor) removed entirely */
  }
}
