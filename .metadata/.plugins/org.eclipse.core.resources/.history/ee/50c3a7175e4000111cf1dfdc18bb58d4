{
    /* USER CODE BEGIN Error_Handler_Debug */
    __disable_irq();
    /* Solid red LED on error */
    HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_SET);
    while (1) {}
    /* USER CODE END Error_Handler_Debug */
}
