/**
 ******************************************************************************
 * @file    main.c  —  BOARD 1: Engine ECU
 * @brief   CAN Bus ECU Simulator — Engine Node
 *
 * Hardware:  STM32F407G-DISC1
 * Sensors:   MAX6675 thermocouple (SPI2 — SCK:PB13, MISO:PB14, CS:PB10)
 *            Joystick (ADC1 — PA1)
 *            Flame sensor digital out (PB1, active low)
 *            USER button (PA0, active low)
 * Actuators: Buzzer (PE0, active high)
 * CAN:       CAN1 via TJA1050 — PD0(RX), PD1(TX) — 500 kbps
 *            Prescaler=6, BS1=11Tq, BS2=2Tq, APB1=42MHz
 * Debug:     USART2 — PA2(TX), PA3(RX) — 115200 baud
 * RTOS:      FreeRTOS CMSIS_V2, heap=15360
 *
 * CAN Message Table
 * -----------------
 *  ID     Signal          Bytes  Cycle   Encoding
 *  0x100  Engine RPM      2      10 ms   raw uint16, 0xFFFF = sensor fault
 *  0x101  Vehicle Speed   1      10 ms   km/h uint8
 *  0x102  Engine Temp     2      10 ms   (temp * 10) uint16, MSB first
 *  0x103  Relay Command   1      10 ms   0x01=ON, 0x00=OFF
 *  0x104  System State    1      10 ms   0=NORMAL 1=FAULT 2=LIMP 3=RECOVER
 *  0x1FE  Flame Emergency 1      event   0xFF = emergency
 *  0x1FF  DTC Code        3      event   [P][code_hi][code_lo]
 *
 * FreeRTOS Task Map
 * -----------------
 *  Task_SensorRead    10 ms   Normal          reads ADC + MAX6675
 *  Task_CANTransmit   10 ms   Normal          transmits all 5 frames
 *  Task_FaultDetect    5 ms   AboveNormal     4-state machine + DTC
 *  Task_LEDHeartbeat 500 ms   BelowNormal     LED state indication
 ******************************************************************************
 */

