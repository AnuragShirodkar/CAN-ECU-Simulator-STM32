/*
 * TFT_DrawStaticFrame — draws all static labels and borders once.
 * Call only on init or after full screen clear.
 *
 * Layout:
 *  [0,0]  128x18   Blue title bar
 *  [2,20] 60x46    RPM panel
 *  [66,20] 60x46   Speed panel
 *  [2,70] 60x46    Temp panel
 *  [66,70] 60x46   State panel
 *  [0,118] 128x16  DTC strip
 *  [0,136] 128x24  Status bar
 */
static void TFT_DrawStaticFrame(void)
{
    /* Title bar */
    ST7735_FillRectangle(0, 0, 128, 18, ST7735_BLUE);
    ST7735_WriteString(8, 5, "ECU DASHBOARD", ST7735_WHITE, ST7735_BLUE);

    /* RPM panel outline + label */
    ST7735_DrawRectangle(2, 20, 60, 46, ST7735_CYAN);
    ST7735_WriteString(5, 23, "RPM", ST7735_CYAN, ST7735_BLACK);

    /* Speed panel outline + label */
    ST7735_DrawRectangle(66, 20, 60, 46, ST7735_GREEN);
    ST7735_WriteString(69, 23, "SPEED", ST7735_GREEN, ST7735_BLACK);

    /* Temp panel outline + label */
    ST7735_DrawRectangle(2, 70, 60, 46, ST7735_ORANGE);
    ST7735_WriteString(5, 73, "TEMP C", ST7735_ORANGE, ST7735_BLACK);

    /* State panel outline + label */
    ST7735_DrawRectangle(66, 70, 60, 46, ST7735_YELLOW);
    ST7735_WriteString(69, 73, "STATE", ST7735_YELLOW, ST7735_BLACK);

    /* DTC strip background */
    ST7735_FillRectangle(0, 118, 128, 16, ST7735_DARKGREY);
    ST7735_WriteString(3, 121, "DTC:", ST7735_WHITE, ST7735_DARKGREY);

    /* Status bar background */
    ST7735_FillRectangle(0, 136, 128, 24, ST7735_DARKGREY);
    ST7735_WriteString(3, 140, "CAN 500kbps", ST7735_WHITE, ST7735_DARKGREY);
}

/*
 * TFT_UpdateAllValues — redraws live data cells only.
 * Clears each cell area before writing to prevent ghost digits.
 */
static void TFT_UpdateAllValues(void)
{
    char buf[16];

    /* ── RPM cell [4,33] 54x20 ── */
    ST7735_FillRectangle(4, 33, 54, 20, ST7735_BLACK);
    if (rx_rpm == 0xFFFF)
        ST7735_WriteString(4, 35, "FAULT", ST7735_RED, ST7735_BLACK);
    else {
        snprintf(buf, sizeof(buf), "%5u", rx_rpm);
        ST7735_WriteString(4, 35, buf, ST7735_CYAN, ST7735_BLACK);
    }

    /* ── Speed cell [68,33] 54x20 ── */
    ST7735_FillRectangle(68, 33, 54, 20, ST7735_BLACK);
    snprintf(buf, sizeof(buf), "%3u", rx_speed);
    ST7735_WriteString(68, 35, buf, ST7735_GREEN, ST7735_BLACK);
    ST7735_WriteString(95, 35, "kmh", ST7735_GREEN, ST7735_BLACK);

    /* ── Temp cell [4,83] 54x20 ── */
    ST7735_FillRectangle(4, 83, 54, 20, ST7735_BLACK);
    snprintf(buf, sizeof(buf), "%5.1f", rx_temp);
    uint16_t tempColor = (rx_temp > 800.0f) ? ST7735_RED :
                         (rx_temp > 600.0f) ? ST7735_YELLOW : ST7735_ORANGE;
    ST7735_WriteString(4, 85, buf, tempColor, ST7735_BLACK);

    /* ── State cell [68,83] 54x20 ── */
    ST7735_FillRectangle(68, 83, 54, 20, ST7735_BLACK);
    uint16_t stColor;
    switch (rx_sysState) {
        case SYS_NORMAL:  stColor = ST7735_GREEN;  break;
        case SYS_FAULT:   stColor = ST7735_RED;    break;
        case SYS_LIMP:    stColor = ST7735_YELLOW; break;
        case SYS_RECOVER: stColor = ST7735_CYAN;   break;
        default:          stColor = ST7735_WHITE;  break;
    }
    ST7735_WriteString(68, 85, (const char *)stateStr, stColor, ST7735_BLACK);

    /* ── DTC strip [30,121] ── */
    ST7735_FillRectangle(30, 121, 95, 11, ST7735_DARKGREY);
    uint16_t dtcColor = (strcmp((const char *)dtcStr, "NONE") == 0)
                        ? ST7735_GREEN : ST7735_RED;
    ST7735_WriteString(30, 121, (const char *)dtcStr, dtcColor, ST7735_DARKGREY);

    /* ── Frame counter in status bar [68,140] ── */
    ST7735_FillRectangle(68, 140, 57, 12, ST7735_DARKGREY);
    snprintf(buf, sizeof(buf), "F:%lu", rx_frameCount);
    ST7735_WriteString(68, 140, buf, ST7735_WHITE, ST7735_DARKGREY);
}

static void Buzzer_Beep(uint8_t times)
{
    for (uint8_t i = 0; i < times; i++) {
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_SET);
        osDelay(200);
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_RESET);
        osDelay(150);
    }
}

