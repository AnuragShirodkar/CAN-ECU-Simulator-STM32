/*
 * Task_TFT_Update — 100 ms period, Normal priority
 * Redraws live value cells on the TFT.
 */
static void Task_TFT_Update(void *argument)
{
    for (;;)
    {
        if (displayDirty)
        {
            displayDirty = 0;
            TFT_UpdateAllValues();

        }
        osDelay(100);
    }
}

/*
 * Task_ThresholdCheck — 50 ms period, AboveNormal priority
 * Local threshold validation as backup to Engine ECU state.
 * Updates LEDs and triggers buzzer on threshold crossings.
 */
static void Task_ThresholdCheck(void *argument)
{
    SystemState_t prevState = SYS_NORMAL;

    for (;;)
    {
        /* ── LED update based on received system state ── */
        switch (rx_sysState)
        {
            case SYS_NORMAL:
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_SET);
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_RESET);
                break;

            case SYS_FAULT:
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_14, GPIO_PIN_SET);
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_13, GPIO_PIN_RESET);
                break;

            case SYS_LIMP:
                HAL_GPIO_TogglePin(GPIOD, GPIO_PIN_13);
                HAL_GPIO_WritePin(GPIOD,  GPIO_PIN_12, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(GPIOD,  GPIO_PIN_14, GPIO_PIN_RESET);
                break;

            case SYS_RECOVER:
                HAL_GPIO_TogglePin(GPIOD, GPIO_PIN_12);
                HAL_GPIO_WritePin(GPIOD,  GPIO_PIN_13, GPIO_PIN_RESET);
                HAL_GPIO_WritePin(GPIOD,  GPIO_PIN_14, GPIO_PIN_RESET);
                break;
        }

        /* ── Local threshold checks (backup to Engine ECU) ── */

        /* RPM overspeed P0219 */
        if (rx_rpm != 0xFFFF && rx_rpm > 8000U &&
            rx_sysState == SYS_NORMAL)
        {
            strncpy((char *)dtcStr, "P0219", 11);
            displayDirty = 1;
            buzzerBeeps  = 1;
            buzzerFlag   = 1;
        }

        /* Temperature critical P0217 */
        if (rx_temp > 800.0f && rx_sysState == SYS_NORMAL)
        {
            strncpy((char *)dtcStr, "P0217", 11);
            HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1, GPIO_PIN_SET); /* relay ON */
            displayDirty = 1;
            buzzerBeeps  = 2;
            buzzerFlag   = 1;
        }

        /* DTC clear on recovery */
        if (rx_sysState == SYS_NORMAL &&
            strcmp((const char *)dtcStr, "NONE") != 0 &&
            strcmp((const char *)dtcStr, "P0335") != 0)
        {
            /* Only clear non-crankshaft DTCs automatically */
            strncpy((char *)dtcStr, "NONE", 11);
            HAL_GPIO_WritePin(GPIOE, GPIO_PIN_1, GPIO_PIN_RESET);
            displayDirty = 1;
        }

        /* Buzzer on state change */
        if (rx_sysState != prevState)
        {
            prevState    = rx_sysState;
            displayDirty = 1;
        }

        osDelay(50);
    }
}

/*
 * Task_BuzzerHandler — 10 ms period, Normal priority
 * Consumes buzzerFlag and drives the buzzer safely outside ISR context.
 */
static void Task_BuzzerHandler(void *argument)
{
    for (;;)
    {
        if (buzzerFlag)
        {
            uint8_t n = buzzerBeeps;
            buzzerFlag = 0;
            Buzzer_Beep(n);
        }
        osDelay(10);
    }
}

