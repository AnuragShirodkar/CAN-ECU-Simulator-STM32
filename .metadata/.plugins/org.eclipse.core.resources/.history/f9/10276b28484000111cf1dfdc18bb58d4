}

/* --- UART Monitor Task Fix --- */
static void User_Task_UARTMonitor(void *arg) {
    static const char *sLabel[] = {"NORMAL","FAULT ","LIMP  ","RECOV "};
    for (;;) {
        char tstr[12];
        FloatToStr(g_canTemp, tstr, 1U);

        char ln[512]; // Increased from 220 to 512 to prevent truncation
        snprintf(ln, sizeof(ln),
            "\r\n+--------------------------------------------+\r\n"
            "|     DASHBOARD ECU — LIVE DATA              |\r\n"
            "+--------------------------------------------+\r\n"
            "| RPM   : %5u rpm                         |\r\n"
            "| Speed : %3u km/h                         |\r\n"
            "| Temp  : %s C                            |\r\n"
            "| Mode  : %-6s                           |\r\n"
            "| Relay : %-14s                   |\r\n"
            "+--------------------------------------------+\r\n",
            (unsigned)g_canRPM, (unsigned)g_canSpeed, tstr,
            sLabel[g_canState & 0x03U], g_canRelay ? "ON" : "OFF");
        UART_Log(ln);
        osDelay(500);
    }
