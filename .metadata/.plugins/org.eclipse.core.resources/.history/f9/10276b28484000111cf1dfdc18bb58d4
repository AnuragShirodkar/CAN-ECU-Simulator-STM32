/* --- Float to String Fix --- */
static void FloatToStr(float v, char *buf, uint8_t decimals) {
    int32_t ipart = (int32_t)v;
    float fpart = v - (float)ipart;
    uint32_t mult = 1U;
    if (fpart < 0.0f) fpart = -fpart;
    for (uint8_t i = 0; i < decimals; i++) mult *= 10U;
    uint32_t frac = (uint32_t)(fpart * (float)mult + 0.5f);
    if (frac >= mult) { ipart++; frac = 0U; }

    if (decimals > 0U) {
        char fmt[16]; // Increased from 8 to 16 to prevent truncation
        snprintf(fmt, sizeof(fmt), "%%ld.%%0%dlu", (int)decimals);
        snprintf(buf, 12, fmt, (long)ipart, (unsigned long)frac);
    } else {
        snprintf(buf, 12, "%ld", (long)ipart);
    }
}

/* --- UART Log Fix --- */
static void UART_Log(const char *msg) {
    // Ensure huart1 is the correct handle for PA9/PA10
    HAL_UART_Transmit(&huart1, (const uint8_t *)msg, (uint16_t)strlen(msg), 200U);
}

static void Buzzer_Beep(uint8_t times) {
    for (uint8_t i = 0; i < times; i++) {
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_SET);
        osDelay(300U);
        HAL_GPIO_WritePin(GPIOE, GPIO_PIN_0, GPIO_PIN_RESET);
        osDelay(200U);
    }
}

/* TFT Functions (Keep your existing TFT_SendCmd, TFT_SendData, TFT_SetWindow, TFT_FillRect, TFT_DrawChar) */
static void ST7735_WriteString(uint8_t x, uint8_t y, const char *str, uint16_t color, uint16_t bgcolor) {
    uint8_t cx = x;
    while (*str != '\0') {
        if ((uint16_t)cx + 6U > TFT_W) break;
        // TFT_DrawChar implementation goes here
        cx = (uint8_t)(cx + 6U);
        str++;
    }
}

/* Dashboard Update Logic */
static void Dashboard_Update(void) {
    char buf[32];
    const uint8_t VX = 32U;
    const uint8_t VW = (uint8_t)(TFT_W - VX);

    // RPM
    snprintf(buf, sizeof(buf), "%5u RPM", (unsigned)g_canRPM);
    ST7735_WriteString(VX, 18U, buf, C_GREEN, C_BLACK);

    // Speed
    snprintf(buf, sizeof(buf), "%3u KMH", (unsigned)g_canSpeed);
    ST7735_WriteString(VX, 34U, buf, C_YELLOW, C_BLACK);

    // Temp
    char tstr[12];
    FloatToStr(g_canTemp, tstr, 1U);
    ST7735_WriteString(VX, 50U, tstr, C_ORANGE, C_BLACK);
}

/* --- CAN RX Callback --- */
void HAL_CAN_RxFifo0MsgPendingCallback(CAN_HandleTypeDef *hcan) {
    CAN_RxHeaderTypeDef rxHdr;
    uint8_t rxData[8];
    if (HAL_CAN_GetRxMessage(hcan, CAN_RX_FIFO0, &rxHdr, rxData) == HAL_OK) {
        g_newData = 1U;
        if (rxHdr.StdId == 0x100U) g_canRPM = ((uint16_t)rxData[0] << 8) | rxData[1];
        if (rxHdr.StdId == 0x101U) g_canSpeed = rxData[0];
        if (rxHdr.StdId == 0x102U) g_canTemp = (float)(((uint16_t)rxData[0] << 8) | rxData[1]) / 10.0f;
    }
}

